{
  "$schema": "https://opencode.ai/config.json",
  "formatter": true,
  "lsp": true,
  "enabled_providers": [
    "zai",
    "opencode",
    "deepseek",
    "mimimax",
    "openai",
    "llama-server"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000
  },
  "provider": {
    "deepseek": {
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "sk-2b3a3b9375834364afc86965e9d9f1af"
      }
    },
    "llama-server": {
      "name": "llama-server cuda-linux:8080",
      "models": {
        "ornith-35b/a3b-think": {
          "name": "Ornith 35B/A3B Think [200k]",
          "system": "You are a 10X software developer",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "qwen3.6-35b/a3b-think": {
          "name": "Qwen3.6 35B/A3B Think [260k]",
          "limit": {
            "context": 260000,
            "output": 8192
          }
        },
        "qwen3.5-9b-mtp-think": {
          "name": "Qwen3.5 9B Mtp Think [262k]",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "gemma4-26b/a4b-think": {
          "name": "Gemma4 26B/A4B Think [120k]",
          "limit": {
            "context": 120000,
            "output": 8192
          }
        },
        "kimi-vl-a3b-think": {
          "name": "Kimi Vl A3B Think [131k]",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "kimi-vl-a3b": {
          "name": "Kimi Vl A3B [131k]",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "glm4.7-30b-a3b-q5-think": {
          "name": "Glm4.7 30B A3B Q5 Think [128k]",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm4.7-30b-a3b-think": {
          "name": "Glm4.7 30B A3B Think [128k]",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      },
      "options": {
        "baseURL": "http://cuda-linux:8080/v1",
        "apiKey": "not.needed"
      }
    }
  },
  "mcp": {
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY"
      },
      "enabled": true
    }
  },
  "plugin": [
    "/home/sal/repos/ponytail/.opencode/plugins/ponytail.mjs"
  ]
}
