#!/usr/bin/env python3

import sys
import subprocess
import argparse
import os
import select

# ANSI color codes for log file only
GREEN = '\033[32m'
CYAN = '\033[36m'
RED = '\033[31m'
RESET = '\033[0m'

def log_stdio(command, log_file, append=True):
    # Open log file in append mode ('a') or write mode ('w')
    mode = 'a' if append else 'w'
    with open(log_file, mode) as log:
        process = subprocess.Popen(
            command,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
            universal_newlines=True
        )

        # Set up polling
        poller = select.poll()
        poller.register(sys.stdin, select.POLLIN)
        poller.register(process.stdout, select.POLLIN)
        poller.register(process.stderr, select.POLLIN)

        while True:
            ready = poller.poll(10)  # 10ms timeout
            for fd, event in ready:
                if fd == sys.stdin.fileno():
                    line = sys.stdin.readline()
                    if not line:  # EOF
                        process.stdin.close()
                        poller.unregister(sys.stdin)
                    else:
                        log.write(f"{CYAN}STDIN:  {line}{RESET}")
                        process.stdin.write(line)
                        process.stdin.flush()
                        log.flush()
                elif fd == process.stdout.fileno():
                    line = process.stdout.readline()
                    if not line:
                        poller.unregister(process.stdout)
                    else:
                        sys.stdout.write(line)
                        sys.stdout.flush()
                        log.write(f"{GREEN}STDOUT: {line}{RESET}")
                        log.flush()
                elif fd == process.stderr.fileno():
                    line = process.stderr.readline()
                    if not line:
                        poller.unregister(process.stderr)
                    else:
                        sys.stderr.write(line)
                        sys.stderr.flush()
                        log.write(f"{RED}STDERR: {line}{RESET}")
                        log.flush()

            if process.poll() is not None:
                break

def main():
    parser = argparse.ArgumentParser(description="Log stdin, stdout, and stderr while executing a command.")
    group = parser.add_mutually_exclusive_group()
    group.add_argument('-o', '--output', dest='output', metavar='FILE', default='stdio.log', 
                       help="Append output to log file (default: stdio.log)")
    group.add_argument('-O', '--overwrite', dest='overwrite', metavar='FILE',
                       help="Overwrite log file instead of appending")
    parser.add_argument('command', nargs=argparse.REMAINDER, help="Command to execute (default: cat)")

    args = parser.parse_args()

    if not args.command:
        args.command = ['cat']
    
    # Determine log file path and append mode
    if args.overwrite:
        log_file = args.overwrite
        append = False
    else:
        log_file = args.output
        append = True

    log_stdio(args.command, log_file, append)

if __name__ == "__main__":
    main()
