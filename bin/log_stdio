#!/usr/bin/env python3

import sys
import subprocess
import argparse
import os

def log_stdio(command, log_file):
    # Open the log file
    with open(log_file, 'a') as log:
        # Create a subprocess
        process = subprocess.Popen(
            command,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
            universal_newlines=True
        )

        # Handle stdin
        for line in sys.stdin:
            log.write(f"STDIN > {line}")
            process.stdin.write(line)
            process.stdin.flush()

        # Close stdin to signal EOF to the subprocess
        process.stdin.close()

        # Handle stdout
        for line in process.stdout:
            sys.stdout.write(line)
            sys.stdout.flush()
            log.write(f"STDOUT < {line}")

        # Handle stderr
        for line in process.stderr:
            sys.stderr.write(line)
            sys.stderr.flush()
            log.write(f"STDERR < {line}")

        # Wait for the process to complete
        process.wait()

def main():
    parser = argparse.ArgumentParser(description="Log stdin, stdout, and stderr while executing a command.")
    parser.add_argument('-o', '--output', default='stdio.log', help="Output log file (default: stdio.log)")
    parser.add_argument('command', nargs=argparse.REMAINDER, help="Command to execute (default: cat)")

    args = parser.parse_args()

    # If no command is specified, use 'cat'
    if not args.command:
        args.command = ['cat']

    log_stdio(args.command, args.output)

if __name__ == "__main__":
    main()
