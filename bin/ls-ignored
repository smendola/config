#!/bin/bash

# List files and folders ignored by .gitignore in the current git repo

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "Error: Not inside a git repository" >&2
    exit 1
fi

ignored=$(git ls-files --ignored --exclude-standard --others --directory 2>/dev/null)

if [[ -z "$ignored" ]]; then
    echo "No ignored files or folders found."
    exit 0
fi

folders=()
files=()

while IFS= read -r item; do
    if [[ "$item" == */ ]]; then
        folders+=("$item")
    else
        files+=("$item")
    fi
done <<< "$ignored"

# Colors
BOLD='\033[1m'
BLUE='\033[1;34m'
GREEN='\033[1;32m'
RESET='\033[0m'

if [[ ${#folders[@]} -gt 0 ]]; then
    echo -e "${BOLD}${BLUE}Folders:${RESET}"
    for f in "${folders[@]}"; do
        echo -e "  ${BLUE}•${RESET} $f"
    done
fi

if [[ ${#files[@]} -gt 0 ]]; then
    [[ ${#folders[@]} -gt 0 ]] && echo
    echo -e "${BOLD}${GREEN}Files:${RESET}"
    for f in "${files[@]}"; do
        echo -e "  ${GREEN}•${RESET} $f"
    done
fi
