#!/bin/bash

if [[ $1 == "mods" ]]
then
  declare -a mods=($(git status -s -uno | sed -e 's/^.* //g'))
  exec ttysend "${mods[@]}"
fi

if [[ $1 == "diffs" ]]
then
  shift
  exec tty-send-diffs "$@"
fi

for file in "$@"; do
  if [[ ! -e "$file" ]]; then
    echo "No such file or directory: $file" >&2
    exit 1
  fi
done

clear
echo -n -e '\e[32m'
echo '###########################################################################'
echo '# Paste all that follows this into a TTY window on the target machine     #'
echo '###########################################################################'
echo -e '\e[0m'
(
echo ' (base64 -d | tar Jxpf -) << EOF'
tar Jcf - "$@" | base64
echo EOF
) | tee /dev/tty | (xsel -i -b 2>/dev/null && echo -e '\e[32m(Sent to clipboard)\e[m') || ( echo -e '\e[31m(No clipboard)\e[m' )
