#!/bin/bash -exv

echo "INSTALLING WGET, CURL, XSEL"
install -A -q wget curl xsel

if command -v apt-get &>/dev/null; then
    echo "REGISTERING SOME REPOS"
    # SublimeText repo
    wget -qO - https://download.sublimetext.com/sublimehq-pub.gpg | gpg --dearmor | sudo tee /etc/apt/trusted.gpg.d/sublimehq-archive.gpg > /dev/null
    echo "deb https://download.sublimetext.com/ apt/stable/" | sudo tee /etc/apt/sources.list.d/sublime-text.list
fi

echo "INSTALLING SOME UTILITIES"
grep -qi microsoft /proc/version 2>/dev/null && install -A -q wslu
install -A -q zip unzip dos2unix direnv htop

echo "INSTALLING CHROME BROWSER"
install -A -q google-chrome-stable || {
    _deb=$(mktemp /tmp/chrome-XXXXXX.deb)
    wget -q "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb" -O "$_deb" \
        && { sudo dpkg -i "$_deb" || sudo apt-get install -f -y; }
    rm -f "$_deb"
} || echo "WARNING: Chrome install failed, continuing..."

echo "INSTALLING JAVA"
install -A -q openjdk-11-jdk || echo "WARNING: Java install failed, continuing..."

echo "INSTALLING SUBLIME TEXT"
install -A -q sublime-text

echo "FETCHING MESLO FONTS"
test ! -d Meslo-Font && git clone https://github.com/andreberg/Meslo-Font.git
# TODO: Install the fonts now

echo "INSTALLING GITHUB CLI"
install -A -q gh

if ! aws --version 2>&1 > /dev/null
then
echo "INSTALLING AWS CLI"
(cd /tmp
  curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip"
  unzip awscliv2.zip
  sudo ./aws/install
)
fi

echo "INSTALLING TILIX"
install -A -q tilix

echo "INSTALLING MISC STUFF"
install -A -q micro meld direnv apt-file xdg-utils desktop-file-utils
install -A -q usbutils net-tools apt-file dnsutils bind9-host

install -A -q jq
install -A -q ntp ntpdate || echo "FAILED TO INSTALL ntp, ntpdate"

install -A -q ngrok

echo "INSTALLING GIT-DELTA"
install -A -q git-delta

#echo "INSTALLING OOKLA SPEEDTEST"
#curl -s https://packagecloud.io/install/repositories/ookla/speedtest-cli/script.deb.sh | sudo bash
#install speedtest
