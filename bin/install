#!/usr/bin/env bash
set -e

interactive=0 quiet=0 all=0
while getopts ':iqyAh' opt; do
    case $opt in
        i)  interactive=1 ;;
        q)  quiet=$(( quiet + 1 )) ;;
        y|A) all=1 ;;
        h)  echo "Usage: $(basename "$0") [-i] [-q|-qq] [-y|-A] PKG [PKG...]" >&2; exit 0 ;;
        *)  echo "Usage: $(basename "$0") [-i] [-q|-qq] [-y|-A] PKG [PKG...]" >&2; exit 1 ;;
    esac
done
shift $(( OPTIND - 1 ))
(( $# )) || { echo "Usage: $(basename "$0") [-i] [-q|-qq] [-y|-A] PKG [PKG...]" >&2; exit 1; }

y()   { (( interactive )) || echo "$1"; }
log() { (( quiet < 1 )) && echo "$@" || true; }
ok()  { (( quiet < 2 )) && echo "Installed with: $*" || true; }
_tmp=$(mktemp)
trap 'rm -f "$_tmp"' EXIT
redir() {
    "$@" >"$_tmp" 2>&1 && { (( quiet < 2 )) && cat "$_tmp"; return 0; } || return 1
}
redir_final() {
    "$@" >"$_tmp" 2>&1 && { (( quiet < 2 )) && cat "$_tmp"; return 0; } || { cat "$_tmp" >&2; return 1; }
}

if command -v apt-get &>/dev/null; then
    redir sudo apt-get install $(y -y) "$@" && ok "apt-get install $*" && exit
elif command -v yum &>/dev/null; then
    redir sudo yum install $(y -y) "$@" && ok "yum install $*" && exit
elif command -v pacman &>/dev/null; then
    redir sudo pacman -S $(y --noconfirm) "$@" && ok "pacman -S $*" && exit
fi

if (( !all )); then
    read -rp "No standard package manager found for: $*. Try alternatives (paru, npm, brew, cargo)? [Y/n] " ans
    [[ "$ans" =~ [nN] ]] && exit 1
fi

for mgr in paru npm brew cargo; do
    command -v "$mgr" &>/dev/null || continue
    log "Trying $mgr..."
    case $mgr in
        paru)   redir_final paru -S $(y --noconfirm) "$@" && ok "paru -S $*" && exit ;;
        npm)    redir_final npm install -g "$@" && ok "npm install -g $*" && exit ;;
        brew)   redir_final brew install "$@" && ok "brew install $*" && exit ;;
        cargo)  redir_final cargo install "$@" && ok "cargo install $*" && exit ;;
    esac
done

echo "No package manager succeeded." >&2
exit 1
