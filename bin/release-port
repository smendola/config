#!/bin/sh

if [ $# -eq 0 ]; then
  echo "Usage: release-port [-9] [-i] PORT"
  exit 1
fi

SIGNAL=""
INTERACTIVE=0

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      echo "Usage: release-port [-9] [-i] PORT"
      echo "  -9  Use SIGKILL instead of SIGTERM"
      echo "  -i  Interactive mode (ask before killing)"
      exit 0
      ;;
    -9) SIGNAL="-9"; shift ;;
    -i) INTERACTIVE=1; shift ;;
    -*) echo "Unknown option: $1"; exit 1 ;;
    *) PORT="$1"; shift ;;
  esac
done

if [ -z "$PORT" ]; then
  echo "Usage: release-port [-9] [-i] PORT"
  exit 1
fi

case "$PORT" in
  ''|*[!0-9]*) echo "Error: PORT must be a number"; exit 1 ;;
esac

PIDS=$(lsof -ti:$PORT)

if [ -z "$PIDS" ]; then
  echo "No process found on port $PORT"
  exit 0
fi

for PID in $PIDS; do
  ps -p $PID -o args=
done

if [ $INTERACTIVE -eq 1 ]; then
  printf "Kill this process? [y/N] "
  read -r answer
  case "$answer" in
    [Yy]*) ;;
    *) echo "Aborted"; exit 0 ;;
  esac
fi

for PID in $PIDS; do
  kill $SIGNAL $PID
done
