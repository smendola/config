#!/bin/bash -e

# Usage:
#  send PATH ...
#  send mods
#  send diffs [PATH ...]
#  Can send mix of files and dirs
#  If PATH is exactly 'mods' it will instead send
#  files that are modified in git
#  If PATH is exactly 'diffs' it will send a patch produced by
#  `git diff -U1 HEAD [PATH ...]` which will be auto-applied via `git apply`
# The output of this command includes the command
# to be used on the receiving end to receive the files.
# If possible, the command is also sent to the clipboard.

TMP_FILE=send.$$.tar
# Optional temp dir for diffs mode
TMP_DIR=""

# Ensure we always clean up temp artifacts
trap "rm -f $TMP_FILE; [ -n \"$TMP_DIR\" ] && rm -rf \"$TMP_DIR\"" EXIT

Z=6
if [[ $1 =~ ^-[0-9]$ ]]
then
  Z=${1#-}
  shift
fi

if [[ $1 == "mods" ]]
then
  declare -a mods=( $(git status -s -uno | sed -e 's/^.* //g') )
  exec send "${mods[@]}"
fi

# If the user wants to send diffs, create a temporary patch file to package
DIFFS_MODE=0
if [[ $1 == "diffs" ]]
then
  shift
  TMP_DIR=$(mktemp -d -t senddiffs.XXXXXX)
  # Collect the diff content (force plain output; omit --binary to keep GNU patch-compatible)
  if ! git diff --no-ext-diff --no-color -U1 HEAD -- "$@" > "$TMP_DIR/diff.patch"; then
    echo "Failed to create diff" >&2
    exit 1
  fi
  if [[ ! -s "$TMP_DIR/diff.patch" ]]; then
    echo "No changes found" >&2
    exit 1
  fi
  DIFFS_MODE=1
fi

read -sp "Passphrase for encryption, empty for unencrypted: " password
echo

# Check if the password is blank
if [[ -z "$password" ]];
then
  echo -e '\e[31m*** Sending unencrypted ***\e[m'
  if [[ $DIFFS_MODE -eq 1 ]]; then
    (set -x; tar cf - -C "$TMP_DIR" diff.patch | gpg --store -z $Z -a -o "$TMP_FILE")
  else
    (set -x; tar cf - "$@" | gpg --store -z $Z -a -o "$TMP_FILE")
  fi
else
  if [[ $DIFFS_MODE -eq 1 ]]; then
    tar cf - -C "$TMP_DIR" diff.patch |
    (set -x; gpg --batch --passphrase-fd 3 -ac -z $Z -o "$TMP_FILE" 3<<<"$password")
  else
    tar cf - "$@" |
    (set -x; gpg --batch --passphrase-fd 3 -ac -z $Z -o "$TMP_FILE" 3<<<"$password")
  fi
fi

json=$(set -x ; curl -F "files[]=@${TMP_FILE}" https://uguu.se/upload.php)
# echo "$json" | jq

link=$(echo "$json" | jq -r '.files[0].url' )
expires=$(echo "$json" | jq -r .expires )


if [[ -z $link ]]
then
  echo "$json" >&2
  exit 1
fi

n=${link##*/}
if [[ $DIFFS_MODE -eq 1 ]]; then
  receive_cmd="(T=/tmp/$n.gpg; (test -f \$T || curl -f -s '$link' -o \$T) && gpg -d -o- \$T | tar xfvv - && patch -p1 < diff.patch && /bin/rm -f diff.patch \$T)"
else
  receive_cmd="(T=/tmp/$n.gpg; (test -f \$T || curl -f -s '$link' -o \$T) && gpg -d -o- \$T | tar xfvv - && /bin/rm -f \$T)"
fi
echo -n -e '\e[32m'
echo "To receive the file, use the following command:"
echo -e '\e[m'
echo $receive_cmd
echo ""
(echo "$receive_cmd" | xsel -i -b 2>/dev/null && echo -e '\e[32m(Sent to clipboard)\e[m') || ( echo -e '\e[31m(No clipboard)\e[m' )

#echo "Expires: $expires"
