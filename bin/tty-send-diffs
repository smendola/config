#!/bin/bash

# Get the diff content
diff_content=$(git diff -U1 HEAD "$@")

if [[ -z "$diff_content" ]]; then
    echo "No changes found" >&2
    exit 1
fi

clear
echo -n -e '\e[32m'
echo '###########################################################################'
echo '# Paste all that follows this into a TTY window on the target machine     #'
echo '###########################################################################'
echo -e '\e[0m'

(
  echo 'base64 -d << EOF | gunzip | git apply'
  echo "$diff_content" | gzip | base64
  echo 'EOF'
) | tee /dev/tty | (xsel -i -b 2>/dev/null && echo -e '\e[32m(Sent to clipboard)\e[m') || (echo -e '\e[31m(No clipboard)\e[m')
